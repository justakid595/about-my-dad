    <!-- Watermark -->
    <div style="position:fixed;bottom:12px;right:12px;padding:6px 14px;font-size:11px;font-weight:600;letter-spacing:0.05em;border-radius:999px;background:rgba(255,255,255,0.9);border:1px solid rgba(14,165,233,0.3);color:rgba(3,105,161,0.8);backdrop-filter:blur(10px);z-index:9999">⚡ Built with BuildCraft</div>

    <script>
        lucide.createIcons();

        // Reveal logic
        const callback = (entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('active');
                }
            });
        };
        const observer = new IntersectionObserver(callback, { threshold: 0.1 });
        document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    </script>
