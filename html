<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gaurav Johri | Software Engineering Strategist | redgauravj@gmail.com</title>
    
    <!-- Premium Typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>

    <style>
        :root {
            --bg: #fdfeff;
            --surface: #ffffff;
            --primary: #0f172a;
            --secondary: #64748b;
            --accent: #0ea5e9;
            --accent-soft: #f0f9ff;
            --accent-deep: #0369a1;
            --border: #e2e8f0;
            --transition: all 0.5s cubic-bezier(0.22, 1, 0.36, 1);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        html { scroll-behavior: smooth; }

        body {
            background-color: var(--bg);
            color: var(--primary);
            font-family: 'Plus Jakarta Sans', sans-serif;
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }

        /* Fixed Email Sidebar (Desktop Only) */
        .email-sidebar {
            position: fixed;
            right: 40px;
            bottom: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 20px;
            z-index: 100;
        }
        .email-sidebar a {
            writing-mode: vertical-rl;
            text-decoration: none;
            color: var(--secondary);
            font-weight: 600;
            font-size: 0.85rem;
            letter-spacing: 2px;
            transition: var(--transition);
        }
        .email-sidebar a:hover { color: var(--accent); transform: translateY(-5px); }
        .email-sidebar::after { content: ""; width: 1px; height: 100px; background: var(--border); }

        /* Navigation */
        nav {
            position: fixed;
            top: 0; width: 100%;
            padding: 24px 8%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 1000;
            backdrop-filter: blur(20px);
            background: rgba(253, 254, 255, 0.8);
            border-bottom: 1px solid var(--border);
        }

        .nav-logo { font-weight: 800; font-size: 1.2rem; color: var(--primary); text-decoration: none; }
        .nav-email-btn {
            background: var(--primary);
            color: #fff;
            padding: 10px 20px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.9rem;
            transition: var(--transition);
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .nav-email-btn:hover { background: var(--accent); transform: scale(1.05); }

        /* Main Hero */
        section { padding: 140px 10% 80px; max-width: 1400px; margin: 0 auto; }

        .hero { text-align: center; display: flex; flex-direction: column; align-items: center; }
        
        .hero-badge {
            background: var(--accent-soft);
            color: var(--accent-deep);
            padding: 8px 20px;
            border-radius: 100px;
            font-weight: 700;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 30px;
            border: 1px solid rgba(14, 165, 233, 0.1);
        }

        h1 { font-size: clamp(2.8rem, 8vw, 5.2rem); font-weight: 800; line-height: 1; letter-spacing: -3px; margin-bottom: 30px; }
        h1 span { color: var(--accent); }

        .hero p { font-size: 1.2rem; color: var(--secondary); max-width: 650px; margin-bottom: 40px; }

        /* Stats & Experience */
        .stats-row {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin-top: 60px;
            width: 100%;
        }

        .stat-card {
            background: #fff;
            padding: 40px 30px;
            border-radius: 20px;
            border: 1px solid var(--border);
            transition: var(--transition);
            text-align: left;
        }
        .stat-card:hover { border-color: var(--accent); transform: translateY(-10px); box-shadow: 0 30px 60px -15px rgba(0,0,0,0.05); }
        .stat-card h2 { font-size: 2.2rem; font-weight: 800; margin-bottom: 10px; }
        .stat-card p { color: var(--secondary); font-size: 0.9rem; font-weight: 500; }

        /* Professional Highlights */
        .highlights { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start; margin-top: 100px; }
        .list-item { margin-bottom: 30px; }
        .list-item h3 { font-size: 1.4rem; margin-bottom: 10px; display: flex; align-items: center; gap: 12px; }
        .list-item p { color: var(--secondary); padding-left: 36px; }

        /* CTA Section */
        .cta-wrap {
            background: var(--primary);
            color: #fff;
            padding: 100px 50px;
            border-radius: 40px;
            text-align: center;
            margin-top: 80px;
            position: relative;
            overflow: hidden;
        }

        .cta-wrap h2 { font-size: 3.5rem; margin-bottom: 20px; }
        .contact-pill {
            display: inline-flex;
            align-items: center;
            gap: 15px;
            background: rgba(255,255,255,1);
            color: var(--primary);
            padding: 20px 40px;
            border-radius: 20px;
            text-decoration: none;
            font-size: 1.3rem;
            font-weight: 800;
            margin-top: 30px;
            transition: var(--transition);
        }
        .contact-pill:hover { background: var(--accent); color: white; transform: scale(1.05); }

        /* Footer */
        footer { padding: 80px 10% 40px; text-align: center; border-top: 1px solid var(--border); margin-top: 100px; }
        .son-tag {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 10px 20px;
            background: var(--accent-soft);
            color: var(--accent-deep);
            border-radius: 99px;
            font-size: 0.85rem;
            font-weight: 700;
            margin-top: 20px;
        }

        @media (max-width: 900px) {
            .highlights { grid-template-columns: 1fr; gap: 40px; }
            h1 { font-size: 3.5rem; }
            .cta-wrap h2 { font-size: 2.5rem; }
            .contact-pill { font-size: 1rem; padding: 15px 25px; }
            .email-sidebar { display: none; }
        }

        .reveal { opacity: 0; transform: translateY(30px); transition: 1s cubic-bezier(0.22, 1, 0.36, 1); }
        .reveal.active { opacity: 1; transform: translateY(0); }
    </style>
</head>
